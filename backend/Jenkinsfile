pipeline {
    agent any
    
    tools {
        nodejs 'nodejs'
        'dependency-check' 'DC'
    }
    
    environment {
        SONAR_SCANNER = tool "sonarqube-scanner-tool"
    }

    options {
        buildDiscarder logRotator(artifactDaysToKeepStr: '', artifactNumToKeepStr: '', daysToKeepStr: '', numToKeepStr: '2')
    }

    stages {
        
        stage('Checkout') {
            steps {
                echo "Checking out code..."
                checkout scm
                script {
                    def shortCommit = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                    env.IMAGE_TAG = "v${env.BUILD_NUMBER}-${shortCommit}"
                }
            }
        }

        stage('Backend Pipeline') {
            when {
                anyOf {
                    changeset 'backend/**'
                    expression { return currentBuild.number == 1 }
                    expression { 
                        // Manual check of the current commit's file list to handle empty changelogs
                        return sh(script: "git log -1 --name-only | grep 'backend/'", returnStatus: true) == 0 
                    }
                }
            }
            stages {
                stage("Build") {
                    steps {
                        echo "Building..."
                        dir('backend') {
                            sh """
                                npm install 
                            """
                        }
                    }
                }

                stage("Tests") {
                    steps {
                        echo "Testing..."
                        dir('backend') {
                            sh """
                                npm test || true
                            """
                        }
                    }
                }

                stage("Security& Quality Analysis") {
                    parallel {
                        stage("Dependency Check") {
                            steps {
                                dir('backend') {
                                    dependencyCheck additionalArguments: '''
                                        --scan .
                                        --format HTML
                                        --format JSON
                                        --format XML
                                        --failOnCVSS 7''', 
                                        nvdCredentialsId: 'owasp-nvd-api-key', 
                                        odcInstallation: 'DC'
                                }
                            }
                            post {
                                always {
                                    dependencyCheckPublisher pattern: '**/dependency-check-report.xml'
                                }
                            }
                        }

                        stage('Code Quality') {
                            stages {
                                stage('SonarQube Analysis') {
                                    steps {
                                        echo 'Running SonarQube analysis...'
                                        withSonarQubeEnv('sonarqube-server') {
                                            sh """
                                                ${SONAR_SCANNER}/bin/sonar-scanner \
                                                    -Dsonar.projectKey=Jerney-Backend \
                                                    -Dsonar.projectName=Jerney-Backend \
                                                    -Dsonar.sources=backend/src \
                                                    -Dsonar.exclusions=node_modules/**,dist/**,coverage/** \
                                                    -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                                                    -Dsonar.sourceEncoding=UTF-8
                                            """
                                        }
                                    }
                                }

                                stage('Quality Gate') {
                                    steps {
                                        echo 'Quality Gate is currently in Non-Blocking mode (Webhook issues)...'
                                        /* 
                                        timeout(time: 10, unit: 'MINUTES') {
                                            waitForQualityGate abortPipeline: true
                                        }
                                        */
                                    }
                                }
                            }
                        }
                    }
                }

                stage('Build Docker Image') {
                    steps {
                        echo 'Building Docker image...'
                        dir('backend') {
                            withCredentials([usernamePassword(credentialsId: 'docker_creds', usernameVariable: 'USERNAME', passwordVariable: 'PASSWORD')]) {
                                sh """
                                    echo "$PASSWORD" | docker login -u "$USERNAME" --password-stdin
                                    docker build -t zohaibwarraich/jerney-backend:${IMAGE_TAG} .
                                """
                            }
                        }
                    }
                }

                stage('Trivy Image Scan') {
                    steps {
                        echo 'Scanning Docker image with Trivy...'
                        sh """
                            trivy image \
                                --severity HIGH,CRITICAL \
                                --exit-code 0 \
                                --no-progress \
                                --format template \
                                --template '@/usr/local/share/trivy/templates/html.tpl' \
                                --output trivy-report.html \
                                zohaibwarraich/jerney-backend:${IMAGE_TAG}
                        """
                    }
                    post {
                        always {
                            publishHTML([
                                allowMissing: false,
                                alwaysLinkToLastBuild: true,
                                keepAll: true,
                                reportDir: '.',
                                reportFiles: 'trivy-report.html',
                                reportName: 'Backend Image Trivy Security Scan Report',
                                reportTitles: 'Trivy Vulnerability Report'
                            ])
                        }
                    }
                }

                stage('Push to DockerHub') {
                    steps {
                        echo 'Pushing image to DockerHub...'
                        withCredentials([usernamePassword(credentialsId: 'docker_creds', usernameVariable: 'USERNAME', passwordVariable: 'PASSWORD')]) {
                            sh """
                                echo "$PASSWORD" | docker login -u "$USERNAME" --password-stdin
                                docker push zohaibwarraich/jerney-backend:${IMAGE_TAG}
                            """
                        }
                    }
                }

                stage('Update Manifest & Helm Values') {
                    steps {
                        echo 'Updating Kubernetes manifest and Helm values...'
                        withCredentials([usernamePassword(credentialsId: 'github_creds', usernameVariable: 'GIT_USERNAME', passwordVariable: 'GIT_PASSWORD')]) {
                            sh """
                                git config user.email "jenkins@gmail.com"
                                git config user.name "Jenkins"
                                
                                # Update Deployment Manifest
                                sed -i 's|image: zohaibwarraich/jerney-backend:.*|image: zohaibwarraich/jerney-backend:${IMAGE_TAG}|g' k8s/backend/deployment.yaml
                                
                                # Update Helm Values
                                # Using sed to find the repository line and update the next line (tag)
                                sed -i '/repository: zohaibwarraich\\/jerney-backend/{n;s/tag: .*/tag: "${IMAGE_TAG}"/;}' helm/values.yaml
                                
                                git add k8s/backend/deployment.yaml helm/values.yaml
                                git commit -m "Update backend image tag to ${IMAGE_TAG} in both helm values.yaml and k8s manifests [skip ci]"
                                git push https://${GIT_USERNAME}:${GIT_PASSWORD}@github.com/zohaibwarraich1/Jerney-real-time-blog-website.git HEAD:main
                            """
                        }
                    }
                }
            }
            post {
                always {
                    echo 'Cleaning up Backend Pipeline images...'
                    sh "docker rmi zohaibwarraich/jerney-backend:${IMAGE_TAG} || true"
                }
            }
        }
    }

    post {
        always {
            echo 'Final Workspace Cleanup...'
            cleanWs()
        }
    }
}
