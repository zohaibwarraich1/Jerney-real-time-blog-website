pipeline {
    agent any
    
    tools {
        nodejs 'nodejs'
        'dependency-check' 'DC'
    }
    
    environment {
        SONAR_SCANNER = tool "sonarqube-scanner-tool"
    }

    options {
        buildDiscarder logRotator(artifactDaysToKeepStr: '', artifactNumToKeepStr: '', daysToKeepStr: '', numToKeepStr: '2')
    }

    stages {
        stage('Frontend Pipeline') {
            when {
                anyOf {
                    changeset "frontend/**"
                    expression {
                        // Safe fallback for classic pipelines
                        return sh(script: "git diff --name-only HEAD~1..HEAD | grep -q '^frontend/'", returnStatus: true) == 0
                    }
                }
            }

            stages {
                stage('Checkout') {
                    steps {
                        echo "Checking out code..."
                        checkout scm
                        script {
                            def shortCommit = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                            env.IMAGE_TAG = "v${env.BUILD_NUMBER}-${shortCommit}"
                        }
                    }
                }

                stage("Build") {
                    steps {
                        echo "Building..."
                        dir('frontend') {
                            sh """
                                npm install 
                            """
                        }
                    }
                }

                stage("Tests") {
                    steps {
                        echo "Testing..."
                        dir('frontend') {
                            sh """
                                npm test || true
                            """
                        }
                    }
                }

                stage("Security& Quality Analysis") {
                    parallel {
                        stage("Dependency Check") {
                            steps {
                                dir('frontend') {
                                    dependencyCheck additionalArguments: '''
                                        --scan .
                                        --format HTML
                                        --format JSON
                                        --format XML
                                        --failOnCVSS 7''', 
                                        nvdCredentialsId: 'owasp-nvd-api-key', 
                                        odcInstallation: 'DC'
                                }
                            }
                            post {
                                always {
                                    dependencyCheckPublisher pattern: '**/dependency-check-report.xml'
                                }
                            }
                        }

                        stage('Code Quality') {
                            stages {
                                stage('SonarQube Analysis') {
                                    steps {
                                        echo 'Running SonarQube analysis...'
                                        dir('frontend') {
                                            withSonarQubeEnv('sonarqube-server') {
                                                sh """
                                                    ${SONAR_SCANNER}/bin/sonar-scanner \
                                                        -Dsonar.projectKey=Jerney-Frontend \
                                                        -Dsonar.projectName=Jerney-Frontend \
                                                        -Dsonar.sources=src \
                                                        -Dsonar.exclusions=node_modules/**,dist/**,coverage/** \
                                                        -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                                                        -Dsonar.sourceEncoding=UTF-8
                                                """
                                            }
                                        }
                                    }
                                }

                                stage('Quality Gate') {
                                    steps {
                                        echo 'Waiting for Quality Gate...'
                                        timeout(time: 10, unit: 'MINUTES') {
                                            waitForQualityGate abortPipeline: true
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                stage('Build Docker Image') {
                    steps {
                        echo 'Building Docker image...'
                        dir('frontend') {
                            withCredentials([usernamePassword(credentialsId: 'docker_creds', usernameVariable: 'USERNAME', passwordVariable: 'PASSWORD')]) {
                                sh """
                                    echo "$PASSWORD" | docker login -u "$USERNAME" --password-stdin
                                    docker build -t zohaibwarraich/jerney-frontend:${IMAGE_TAG} .
                                """
                            }
                        }
                    }
                }

                stage('Trivy Image Scan') {
                    steps {
                        echo 'Scanning Docker image with Trivy...'
                        sh """
                            trivy image \
                                --severity HIGH,CRITICAL \
                                --exit-code 0 \
                                --no-progress \
                                --format template \
                                --template '@/usr/local/share/trivy/templates/html.tpl' \
                                --output trivy-report.html \
                                zohaibwarraich/jerney-frontend:${IMAGE_TAG}
                        """
                    }
                    post {
                        always {
                            publishHTML([
                                allowMissing: false,
                                alwaysLinkToLastBuild: true,
                                keepAll: true,
                                reportDir: '.',
                                reportFiles: 'trivy-report.html',
                                reportName: 'Frontend Image Trivy Security Scan Report',
                                reportTitles: 'Trivy Vulnerability Report'
                            ])
                        }
                    }
                }

                stage('Push to DockerHub') {
                    steps {
                        echo 'Pushing image to DockerHub...'
                        withCredentials([usernamePassword(credentialsId: 'docker_creds', usernameVariable: 'USERNAME', passwordVariable: 'PASSWORD')]) {
                            sh """
                                echo "$PASSWORD" | docker login -u "$USERNAME" --password-stdin
                                docker push zohaibwarraich/jerney-frontend:${IMAGE_TAG}
                            """
                        }
                    }
                }

                stage('Update Manifest & Helm Values') {
                    steps {
                        echo 'Updating Kubernetes manifest and Helm values...'
                        withCredentials([usernamePassword(credentialsId: 'github_creds', usernameVariable: 'GIT_USERNAME', passwordVariable: 'GIT_PASSWORD')]) {
                            sh """
                                git config user.email "jenkins@gmail.com"
                                git config user.name "Jenkins"
                                
                                # Update Deployment Manifest
                                sed -i 's|image: zohaibwarraich/jerney-frontend:.*|image: zohaibwarraich/jerney-frontend:${IMAGE_TAG}|g' k8s/frontend/deployment.yaml
                                
                                # Update Helm Values
                                # Using sed to find the repository line and update the next line (tag)
                                sed -i '/repository: zohaibwarraich\\/jerney-frontend/{n;s/tag: .*/tag: "${IMAGE_TAG}"/;}' helm/values.yaml
                                
                                git add k8s/frontend/deployment.yaml helm/values.yaml
                                git commit -m "Update frontend image tag to ${IMAGE_TAG} in both helm values.yaml and k8s manifests [skip ci]"
                                git push https://${GIT_USERNAME}:${GIT_PASSWORD}@github.com/zohaibwarraich1/Jerney-real-time-blog-website.git HEAD:main
                            """
                        }
                    }
                }
            }
            post {
                always {
                    echo 'Cleaning up Frontend Pipeline images...'
                    sh "docker rmi zohaibwarraich/jerney-frontend:${IMAGE_TAG} || true"
                }
            }
        }
    }

    post {
        always {
            echo 'Final Workspace Cleanup...'
            cleanWs()
        }
    }
}
